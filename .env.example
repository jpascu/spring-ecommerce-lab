# Copia este fichero a .env y ajusta los valores para docker-compose.
# docker compose lee .env automaticamente.

# PostgreSQL
POSTGRES_DB=shopdb
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop

# Secreto para firmar el JWT (HS256 -> minimo 32 bytes). CAMBIALO en cualquier entorno real.
JWT_SECRET=cambia-este-secreto-de-desarrollo-no-usar-en-produccion-1234
