{
  "info": {
    "name": "spring-ecommerce-lab",
    "description": "Colección para probar la API (arquitectura hexagonal). Variable {{baseUrl}} por defecto http://localhost:8080. Ejecuta primero 'Auth > Login (admin)' para obtener el JWT (se guarda en {{token}}); el resto de peticiones lo envían automáticamente como Bearer.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "productId", "value": "" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('devuelve accessToken', () => pm.expect(body.accessToken).to.be.a('string'));",
                  "pm.collectionVariables.set('token', body.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login (user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('token', pm.response.json().accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Health & Ping",
      "item": [
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/ping", "host": ["{{baseUrl}}"], "path": ["api", "ping"] }
          }
        },
        {
          "name": "Actuator Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/actuator/health", "host": ["{{baseUrl}}"], "path": ["actuator", "health"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Listar productos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('contiene content (array)', () => pm.expect(body.content).to.be.an('array'));",
                  "pm.test('tiene metadatos de paginacion', () => { pm.expect(body).to.have.property('page'); pm.expect(body).to.have.property('totalElements'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] }
          }
        },
        {
          "name": "Crear producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('devuelve id', () => pm.expect(body.id).to.be.a('number'));",
                  "pm.collectionVariables.set('productId', body.id);",
                  "pm.test('cabecera Location', () => pm.expect(pm.response.headers.get('Location')).to.include('/api/products/'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Auriculares Bluetooth\",\n  \"description\": \"Cancelacion de ruido\",\n  \"price\": 129.99,\n  \"stock\": 30,\n  \"category\": \"Audio\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] }
          }
        },
        {
          "name": "Obtener producto por id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('id coincide', () => pm.expect(String(pm.response.json().id)).to.eql(pm.collectionVariables.get('productId')));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        },
        {
          "name": "Actualizar producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('precio actualizado', () => pm.expect(pm.response.json().price).to.eql(99.95));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Auriculares Bluetooth Pro\",\n  \"description\": \"Cancelacion de ruido mejorada\",\n  \"price\": 99.95,\n  \"stock\": 25,\n  \"category\": \"Audio\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        },
        {
          "name": "Presupuesto (quote)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const q = pm.response.json();",
                  "pm.test('tiene total y estrategia', () => { pm.expect(q).to.have.property('total'); pm.expect(q).to.have.property('appliedStrategy'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tier\": \"VIP\",\n  \"quantity\": 60,\n  \"couponCode\": \"SAVE20\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}/quote", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}", "quote"] }
          }
        },
        {
          "name": "Borrar producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 204', () => pm.response.to.have.status(204));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        }
      ]
    },
    {
      "name": "Casos de error",
      "item": [
        {
          "name": "Crear invalido (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"price\": -5,\n  \"stock\": -1,\n  \"category\": \"\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] }
          }
        },
        {
          "name": "Obtener inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 404', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/999999", "host": ["{{baseUrl}}"], "path": ["api", "products", "999999"] }
          }
        }
      ]
    }
  ]
}
